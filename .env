# -----------------------------------------------------------------------------
# Alder ERP — environment configuration
# Copy to `.env` and fill in. Never commit the real file.
# -----------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Database — SQLite by default (local-first). Swap for PostgreSQL in production.
ALDER_DATABASE_URL=sqlite:///./alder.db
# ALDER_DATABASE_URL=postgresql+psycopg://alder:alder@localhost:5432/alder

# Obsidian vault
ALDER_OBSIDIAN_VAULT=/mnt/D/Documentos/obsidian/tesserato/Tesserato-document
ALDER_OBSIDIAN_SALES_SUBDIR=Vendas

# Meta WhatsApp Cloud API
# https://developers.facebook.com/docs/whatsapp/cloud-api
ALDER_WHATSAPP_PHONE_NUMBER_ID=
ALDER_WHATSAPP_ACCESS_TOKEN=
ALDER_WHATSAPP_API_VERSION=v19.0
ALDER_WHATSAPP_TIMEOUT_SECS=10

# Async runner
ALDER_ASYNC_WORKERS=2
